-- ⚠️ 이 파일은 자동 적용되지 않음 (.sql 확장자 아님).
--    적용 조건이 충족된 후에 운영자가 수동으로 SQL Editor 에서 실행:
--
--    1) 5단계 instagram-publisher 가 배포되어 있고
--    2) Meta App Review 통과 + IG_PAGE_ACCESS_TOKEN / IG_BUSINESS_ACCOUNT_ID secret 등록 완료
--    3) Supabase Storage 버킷 instagram-cards 가 public 으로 생성됨
--    4) instagram_post_drafts 에 status='scheduled' 인 행이 들어가는 흐름이 정상 작동
--
-- 적용 방법:
--   파일명을 `20260601000000_instagram_pg_cron.sql` 로 바꾸고 git 에 add → push
--   또는 Supabase Dashboard → SQL Editor 에 내용 그대로 붙여넣고 RUN.
--
-- 활성화 즉시 매분 publisher 가 호출되므로 신중하게.
-- ============================================================================

-- pg_cron extension 활성화 (이미 있으면 무시)
CREATE EXTENSION IF NOT EXISTS pg_cron WITH SCHEMA extensions;

-- pg_net extension (http 호출에 필요)
CREATE EXTENSION IF NOT EXISTS pg_net WITH SCHEMA extensions;

