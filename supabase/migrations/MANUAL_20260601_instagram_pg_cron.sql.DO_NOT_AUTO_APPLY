-- ============================================================================
-- 2) 매분 — instagram-publisher 가 status='scheduled' AND scheduled_for <= now() 픽업
--    ※ 발행 시간 매일 10:00 KST 이지만 1분 단위 정확도를 위해 매분 체크
-- ============================================================================
SELECT cron.schedule(
  'dewy-instagram-publish-queue',
  '* * * * *',
  $$
  SELECT net.http_post(
    url := 'https://<PROJECT_REF>.supabase.co/functions/v1/instagram-publisher',
    headers := jsonb_build_object(
      'Content-Type', 'application/json',
      'Authorization', 'Bearer ' || current_setting('app.settings.service_role_key')
    ),
    body := '{}'::jsonb
  );
  $$
);

