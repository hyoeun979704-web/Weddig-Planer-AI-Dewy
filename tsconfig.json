{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/integrations/*": [
        "./packages/db/src/*"
      ],
      "@/components/ui/*": [
        "./packages/ui/src/*"
      ],
      "@/lib/*": [
        "./packages/lib/src/*"
      ],
      "@/hooks/*": [
        "./packages/hooks/src/*"
      ],
      "@/contexts/*": [
        "./packages/shared/src/contexts/*"
      ],
      "@/types/*": [
        "./packages/shared/src/types/*"
      ],
      "@/data/*": [
        "./packages/shared/src/data/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@dewy/lib": [
        "./packages/lib/src/index.ts"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions"
  ]
}
