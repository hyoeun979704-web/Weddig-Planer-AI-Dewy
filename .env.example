VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# ── 광고 (꽃 머지 게임: 하단 배너 + 포인트 2배 보상형) ──
# 웹(AdSense): 미설정이면 배너 미노출, 보상형은 graceful 폴백(보상 지급).
VITE_ADSENSE_CLIENT="ca-pub-XXXXXXXXXXXXXXXX"
VITE_ADSENSE_BANNER_SLOT="1234567890"
# 네이티브(AdMob, Capacitor 안드로이드): @capacitor-community/admob 설치 + cap sync 필요.
# 미설정 시 adService 의 Dewy 광고단위 기본값 사용(ad unit ID 는 공개값이라 안전).
VITE_ADMOB_BANNER_ID="ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX"          # 게임 하단 배너
VITE_ADMOB_REWARDED_ID="ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX"        # 보상형 — 포인트 2배
VITE_ADMOB_REWARDED_EXTRA_ID="ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX"  # 보상형 — 게임기회 1회 추가
