VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# TossPayments 위젯 클라이언트 키 (쇼핑 결제). 없으면 결제 화면이 비활성화됩니다.
VITE_TOSS_CLIENT_KEY="test_ck_your_toss_client_key"

# PortOne (포트원) — 카카오페이/네이버페이/카드 통합 PG.
# 대시보드 → 결제연동 메뉴에서 발급. 라이브 키는 PG 사 심사 후 받습니다.
VITE_PORTONE_STORE_ID="store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # 가맹점 식별코드
VITE_PORTONE_CHANNEL_KEY_KAKAOPAY="channel-key-xxxx"                # 카카오페이 채널
VITE_PORTONE_CHANNEL_KEY_NAVERPAY="channel-key-xxxx"                # 네이버페이 채널
VITE_PORTONE_CHANNEL_KEY_CARD="channel-key-xxxx"                    # 카드(토스페이먼츠) 채널

# Edge Function (서버) 시크릿. .env 에 두지 말고 Supabase Secrets 에 등록.
# PORTONE_V2_API_SECRET=...  # REST API 시크릿 (결제 검증·환불·빌링키)
