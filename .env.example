# ============================================================
# Supabase
# ============================================================
# Next.js (primary)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"

# Vite (legacy, kept for `dev:vite` / `build:vite`)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key"

# Server-only (used by Supabase Edge Functions or Next.js API routes)
# SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# ============================================================
# Figma (SERVER-ONLY — never expose to client)
# ============================================================
# Personal access token from https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN="figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
