<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_sched_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="다가오는 일정"
        android:textColor="#D6336C"
        android:textStyle="bold"
        android:textSize="13sp"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/widget_sched_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="다가오는 일정이 없어요"
        android:textColor="#9A8B90"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp">
        <TextView
            android:id="@+id/widget_sched_1_d"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#D6336C"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_sched_1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text=""
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#3A2E32"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp">
        <TextView
            android:id="@+id/widget_sched_2_d"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#D6336C"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_sched_2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text=""
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#3A2E32"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp">
        <TextView
            android:id="@+id/widget_sched_3_d"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#D6336C"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_sched_3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text=""
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#3A2E32"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
