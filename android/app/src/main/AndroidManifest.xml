<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth deep-link callback: app.dewy://auth/callback (registered in Supabase / Google / Kakao). -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="app.dewy" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- 홈 위젯 4종. exported=false: 시스템 AppWidget 프레임워크/동일앱 갱신만 트리거(보안).
             설계·데이터 흐름: docs/widget-system.md. -->
        <receiver android:name=".widget.ComboWidgetProvider" android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider" android:resource="@xml/widget_combo_info" />
        </receiver>
        <receiver android:name=".widget.DdayWidgetProvider" android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider" android:resource="@xml/widget_dday_info" />
        </receiver>
        <receiver android:name=".widget.ChecklistWidgetProvider" android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider" android:resource="@xml/widget_checklist_info" />
        </receiver>
        <receiver android:name=".widget.BudgetWidgetProvider" android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider" android:resource="@xml/widget_budget_info" />
        </receiver>

        <!-- AdMob App ID (필수). 없거나 틀리면 AdMob SDK 초기화 시 앱이 즉시 죽음.
             Dewy AdMob 앱(pub-3558095447353368)의 실제 App ID.
             (보상형/배너 '광고단위' ID 는 adService 의 VITE_ADMOB_*(또는 기본값)로 별도 주입) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3558095447353368~7146431266" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ (API 33+) 에서 광고 ID 사용을 위한 명시 권한. AdMob 도입 예정
         이며 Play Console 데이터 보안 폼의 광고 ID 수집 선언과 매칭. 권한 없으면
         광고 ID 가 0 으로 처리 → 광고/분석 수익 손실 + Play Console 오류. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
</manifest>
