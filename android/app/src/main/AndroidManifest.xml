<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth deep-link callback: app.dewy://auth/callback (registered in Supabase / Google / Kakao). -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="app.dewy" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- 홈 화면 위젯: D-day / 일정 / 예산. 데이터는 WidgetBridgePlugin 이
             SharedPreferences 에 기록하고, 각 Provider 가 읽어 RemoteViews 로 렌더한다. -->
        <receiver
            android:name="app.dewy.widget.DdayWidgetProvider"
            android:label="Dewy D-day"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_dday_info" />
        </receiver>

        <receiver
            android:name="app.dewy.widget.ScheduleWidgetProvider"
            android:label="Dewy 일정"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_schedule_info" />
        </receiver>

        <receiver
            android:name="app.dewy.widget.BudgetWidgetProvider"
            android:label="Dewy 예산"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_budget_info" />
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+(API 33) 알림 표시 권한. 로컬 알림(D-day/일정/예산) + 푸시(FCM)
         모두 런타임 권한이 필요하다. 플러그인이 런타임에 요청한다. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Android 13+ (API 33+) 에서 광고 ID 사용을 위한 명시 권한. AdMob 도입 예정
         이며 Play Console 데이터 보안 폼의 광고 ID 수집 선언과 매칭. 권한 없으면
         광고 ID 가 0 으로 처리 → 광고/분석 수익 손실 + Play Console 오류. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
</manifest>
