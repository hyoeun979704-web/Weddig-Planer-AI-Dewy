# Release signing 정보 템플릿.
#
# 1) 이 파일을 같은 디렉터리에 keystore.properties 라는 이름으로 복사
# 2) 아래 값을 본인 keytool 발급 정보로 채우기
# 3) keystore.properties 는 .gitignore 에 포함되어 있어 커밋되지 않음
#
# storeFile 경로는 절대경로 권장 (역슬래시는 두 번 \\ 로 이스케이프).
# 또는 슬래시 / 를 써도 Windows 에서 정상 인식.

storeFile=C:/Users/qazws/dewy-release.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=dewy
keyPassword=YOUR_KEY_PASSWORD
