    "test:watch": "vitest",
    "test:e2e": "vite build && playwright test",
    "seed:invitation-templates": "tsx scripts/seedInvitationTemplates.ts",
    "seed:invitation-fonts": "tsx scripts/importInvitationFonts.ts",
    "collect": "tsx scripts/collect-places/index.ts",
    "backfill-images": "tsx scripts/collect-places/backfill-images.ts",
    "enrich-source-refs": "tsx scripts/collect-places/enrich-source-refs.ts",
    "enrich-place-details": "tsx scripts/collect-places/enrich-place-details.ts",
    "enrich-with-gemini": "tsx scripts/collect-places/enrich-with-gemini.ts",
    "import-gemini-json": "tsx scripts/collect-places/import-from-json.ts",
