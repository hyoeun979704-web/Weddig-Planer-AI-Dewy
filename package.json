    "collect-blogs": "tsx scripts/collect-tips/naver-blogs.ts",
    "collect-magazines": "tsx scripts/collect-tips/magazine-rss.ts",
    "cap:sync": "cap sync",
    "cap:build": "vite build --mode capacitor && cap sync",
    "assets:icons": "node scripts/generate-app-icons.mjs",
    "assets:generate": "node scripts/generate-app-icons.mjs && npx --yes @capacitor/assets@^3 generate --iconBackgroundColor #FFFFFF --iconBackgroundColorDark #FFFFFF --splashBackgroundColor #FFFFFF --splashBackgroundColorDark #FFFFFF",
    "android:dev": "npm run cap:build && cap run android",
    "android:open": "cap open android",
    "ios:open": "cap open ios"
